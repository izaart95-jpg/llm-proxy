# LLM Universal Proxy — Environment Configuration

# Port the proxy listens on
PROXY_PORT=4000

# Base URL of the LLM backend (no trailing slash)
# Examples:
#   https://api.openai.com          — OpenAI
#   https://api.anthropic.com       — Anthropic
#   http://localhost:11434          — Ollama
#   https://api.groq.com            — Groq
#   https://api.together.xyz        — Together AI
#   https://openrouter.ai/api/v1    —  Openrouter
#   https://integrate.api.nvidia.com/v1  — NVIDIA NIM
BACKEND_URL=https://api.openai.com

# Which endpoint format does the BACKEND expose?
#   chat      → /v1/chat/completions  (OpenAI, Ollama, Groq, Together, etc.)
#   messages  → /v1/messages          (Anthropic)
#   responses → /v1/responses         (OpenAI Responses API)
BACKEND_FORMAT=chat

# API key forwarded to the backend
# If left empty, the proxy passes through whatever the client sends
# in Authorization or x-api-key headers
BACKEND_API_KEY=

# Anthropic-version header (only used when BACKEND_FORMAT=messages)
ANTHROPIC_VERSION=2026-02-01